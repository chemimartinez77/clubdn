generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Estados posibles de un usuario
enum UserStatus {
  PENDING_VERIFICATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
  BAJA
}

// Roles de usuario
enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}


enum ReportType {
  BUG
  MEJORA
}

enum ReportStatus {
  NUEVO
  EN_REVISION
  EN_PROGRESO
  HECHO
}

enum ReportPriority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum ReportSeverity {
  NO_URGE
  ME_MOLESTA
  BLOQUEANTE
}

enum ReportPlatform {
  MOVIL
  PC
}

// Tipos de membresía
enum MembershipType {
  SOCIO        // 19€/mes, con llave, requiere 1 año como COLABORADOR + aprobación
  COLABORADOR  // 15€/mes, sin llave
  FAMILIAR     // Vinculado a un socio
  EN_PRUEBAS   // Periodo de prueba
  BAJA         // Usuario dado de baja
}

// Modelo de Usuario
model User {
  id                String      @id @default(cuid())
  email             String      @unique
  name              String
  password          String
  role              UserRole    @default(USER)
  status            UserStatus  @default(PENDING_VERIFICATION)

  emailVerified     Boolean     @default(false)
  verificationToken String?     @unique
  tokenExpiry       DateTime?

  resetPasswordToken String?    @unique
  resetPasswordExpiry DateTime?

  calendarToken     String?     @unique

  approvedBy        String?
  approvedAt        DateTime?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectionReason   String?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  lastLoginAt       DateTime?

  approvedByAdmin   User?       @relation("ApprovedUsers", fields: [approvedBy], references: [id])
  approvedUsers     User[]      @relation("ApprovedUsers")
  rejectedByAdmin   User?       @relation("RejectedUsers", fields: [rejectedBy], references: [id])
  rejectedUsers     User[]      @relation("RejectedUsers")

  profile           UserProfile?
  organizedEvents   Event[]              @relation("EventOrganizer")
  cancelledEvents   Event[]              @relation("EventCancelledBy")
  eventRegistrations EventRegistration[]
  membership        Membership?
  payments          Payment[]
  invitationsCreated   Invitation[]     @relation("InvitationsCreated")
  invitationsValidated Invitation[]     @relation("InvitationsValidated")
  invitationsApproved  Invitation[]     @relation("InvitationsApproved")
  shareLinks           EventShareLink[] @relation("ShareLinksCreated")
  loginAttempts     LoginAttempt[]
  uploadedDocuments Document[]
  uploadedPhotos    EventPhoto[]
  reports           Report[]
  reportVotes       ReportVote[]
  assignedReports   Report[]        @relation("AssignedReports")
  reportComments    ReportComment[]
  eventAuditLogs    EventAuditLog[] @relation("EventAuditActor")
  eventAuditTargets EventAuditLog[] @relation("EventAuditTargetUser")
  notifications     Notification[]
  globalNotificationReads GlobalNotificationRead[]
  badges            UserBadge[]
  announcements     Announcement[]
  announcementLikes AnnouncementLike[]
  gamePlayHistory   GamePlayHistory[]
  financialMovements FinancialMovement[] @relation("FinancialMovements")
  azulGamesAsPlayer1  AzulGame[]          @relation("AzulGamesAsPlayer1")
  azulGamesAsPlayer2  AzulGame[]          @relation("AzulGamesAsPlayer2")
  viernesGames        ViernesGame[]       @relation("ViernesGamesAsPlayer")
  pageViews           PageView[]
  gameValidationsAsScanner GameValidation[]    @relation("GameValidationScanner")
  gameValidationsAsScanned GameValidation[]    @relation("GameValidationScanned")
  gameCategoryVotes        GameCategoryVote[]
  genreConsensusHistory    GenreConsensusHistory[]
  marketplaceListings      MarketplaceListing[]           @relation("MarketplaceListingAuthor")
  marketplaceConversations MarketplaceConversation[]      @relation("MarketplaceConversationBuyer")
  marketplaceMessages      MarketplaceMessage[]           @relation("MarketplaceMessageSender")
  marketplaceOffers        MarketplaceOffer[]             @relation("MarketplaceOfferProposer")
  marketplaceCancellations MarketplaceCancellation[]      @relation("MarketplaceCancellationUser")
  marketplaceReads         MarketplaceConversationRead[]  @relation("MarketplaceConversationReadUser")
  userGames                UserGame[]
  gameLocations            GameLocation[]
  bggSyncJobs              BggSyncJob[]
  eventResultsCreated      EventResult[]                  @relation("EventResultCreator")
  eventResults             EventResult[]

  @@index([email])
  @@index([status])
  @@index([verificationToken])
}

// Perfil extendido de usuario
model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Información personal
  avatar          String?  // URL o path del avatar
  nick            String?  // Nombre visible en partidas, feedback, etc.
  firstName       String?
  lastName        String?
  dni             String?
  dniNormalized   String?
  imageConsentActivities Boolean @default(false)
  imageConsentSocial     Boolean @default(false)
  phone           String?
  birthDate       DateTime?
  bio             String?  @db.Text

  // Datos de contacto / domicilio (importados del sistema anterior)
  memberNumber    String?
  joinedAt        DateTime?
  address         String?
  city            String?
  province        String?
  postalCode      String?
  iban            String?

  // Preferencias de juegos
  favoriteGames   String[] // Array de nombres de juegos favoritos
  playStyle       String?  // Competitivo, Casual, Social, etc.

  // Social
  discord         String?
  telegram        String?

  // Configuración
  notifications   Boolean  @default(true)
  emailUpdates    Boolean  @default(false)

  // Preferencias de notificaciones
  notifyNewEvents       Boolean @default(true)   // Notificar nuevas partidas
  notifyEventChanges    Boolean @default(true)   // Cambios en eventos inscritos
  notifyEventCancelled  Boolean @default(true)   // Eventos cancelados
  notifyInvitations     Boolean @default(true)   // Estado de invitaciones
  allowEventInvitations Boolean @default(true)   // Permitir ser apuntado a eventos por otros miembros

  // Personalización
  defaultScreen        String   @default("home")       // Pantalla de inicio tras login: "home" o "events"
  noughterColor        String?                         // Color de Noughter: purple, blue, green, red, brown (null = usar tema activo)
  eventsDefaultView    String   @default("calendar")   // Vista por defecto en Eventos: "calendar" o "list"
  eventsAccordionMode  String   @default("current_only") // Modo acordeón en lista: "current_only" o "all_open"
  eventButtonStyle     String   @default("dropdown")     // Estilo de botones en detalle de evento: "dropdown" o "multicolor"
  onboardingCompleted        Boolean  @default(false)  // true = ha completado el formulario de bienvenida obligatorio
  tourDismissed              Boolean  @default(false)  // true = no volver a mostrar el tour de inicio
  calendarTourDismissed      Boolean  @default(false)  // true = no volver a mostrar el tour del calendario
  feedbackTourDismissed      Boolean  @default(false)  // true = no volver a mostrar el tour de feedback
  createPartidaTourDismissed Boolean  @default(false)  // true = no volver a mostrar el tour de crear partida

  // BGG (BoardGameGeek)
  bggUsername     String?
  lastBggSync     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([dniNormalized])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String?
  content   String
  pinned    Boolean  @default(false)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  likes     AnnouncementLike[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([pinned])
}

model AnnouncementLike {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
}

model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  template    String
  sentAt      DateTime @default(now())
  success     Boolean
  errorMsg    String?

  @@index([to])
  @@index([sentAt])
}

// Registro de intentos de login
model LoginAttempt {
  id          String   @id @default(cuid())
  email       String
  ipAddress   String?
  userAgent   String?
  success     Boolean
  failureReason String?  // "invalid_credentials", "pending_verification", "pending_approval", "rejected", "suspended"
  userId      String?   // Solo si el login fue exitoso o si el usuario existe
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attemptedAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([success])
  @@index([attemptedAt])
  @@index([userId])
}

// Tipos de eventos
enum EventType {
  PARTIDA
  TORNEO
  OTROS
}

// Estados de eventos
enum EventStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

// Estados de registro
enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
  PENDING_APPROVAL  // Registro pendiente de aprobación del organizador
}

enum InvitationStatus {
  PENDING            // Válida, en espera de ser usada en puerta
  PENDING_APPROVAL   // Esperando aprobación del organizador
  USED
  EXPIRED
  CANCELLED
}

// Modelo de Evento
model Event {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text

  // Tipo de evento
  type            EventType @default(OTROS)

  // Datos del juego (opcional, para partidas)
  gameName        String?
  gameImage       String?
  bggId           String?
  game            Game?    @relation("GameEvents", fields: [bggId], references: [id])
  expansions      EventExpansion[]
  gameCategory    BadgeCategory? // Categoría para tracking de badges
  linkedNextEventId   String? @unique
  linkedNextEvent     Event?  @relation("LinkedEventChain", fields: [linkedNextEventId], references: [id])
  linkedPreviousEvent Event?  @relation("LinkedEventChain")

  // Fecha y hora
  date            DateTime
  startHour       Int?      // 0-23
  startMinute     Int?      // 0, 15, 30, 45
  durationHours   Int?      // Duración estimada en horas
  durationMinutes Int?      // Duración estimada en minutos

  // Ubicación
  location        String
  address         String?

  // Capacidad
  maxAttendees    Int
  registrations   EventRegistration[]
  invitations     Invitation[]
  shareLinks      EventShareLink[]
  eventGuests     EventGuest[]
  photos          EventPhoto[]
  auditLogs       EventAuditLog[]
  gamePlayHistory GamePlayHistory[]
  gameValidations GameValidation[]

  // Aprobación de jugadores
  requiresApproval Boolean @default(true) // Si requiere aprobación del organizador

  // Estado
  status              EventStatus @default(SCHEDULED)
  cancelledAt         DateTime?
  cancelledById       String?
  cancelledBy         User?     @relation("EventCancelledBy", fields: [cancelledById], references: [id])
  cancellationReason  String?   // Motivo de cancelación (introducido por el organizador)

  // Confirmación de disputa (¿se jugó la partida?)
  disputeAsked         Boolean   @default(false) // Si ya se le preguntó al organizador
  disputeConfirmedAt   DateTime? // Cuándo respondió
  disputeResult        Boolean?  // true = se jugó, false = no se jugó

  // Organizador
  createdBy       String
  organizer       User     @relation("EventOrganizer", fields: [createdBy], references: [id])

  results         EventResult[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@index([status])
  @@index([createdBy])
  @@index([type])
  @@index([linkedNextEventId])
}

model EventExpansion {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([eventId, gameId])
  @@index([eventId, position])
  @@index([gameId])
}

model Invitation {
  id                  String           @id @default(cuid())
  token               String           @unique
  memberId            String
  member              User             @relation("InvitationsCreated", fields: [memberId], references: [id], onDelete: Cascade)
  guestFirstName      String
  guestLastName       String
  guestPhone          String?
  guestDniNormalized  String?
  eventId             String
  event               Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  validDate           DateTime
  status              InvitationStatus @default(PENDING)
  isExceptional       Boolean          @default(false)
  validatedByUserId   String?
  validatedBy         User?            @relation("InvitationsValidated", fields: [validatedByUserId], references: [id])
  usedAt              DateTime?
  approvedById        String?
  approvedBy          User?            @relation("InvitationsApproved", fields: [approvedById], references: [id])
  approvedAt          DateTime?
  createdAt           DateTime         @default(now())
  eventGuest          EventGuest?

  @@index([eventId])
  @@index([memberId])
  @@index([status])
  @@index([validDate])
  @@index([guestPhone])
}

model EventShareLink {
  id        String   @id @default(cuid())
  token     String   @unique
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  memberId  String
  member    User     @relation("ShareLinksCreated", fields: [memberId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, memberId])
  @@index([token])
}

model EventGuest {
  id            String     @id @default(cuid())
  eventId       String
  event         Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitationId  String     @unique
  invitation    Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  guestFirstName String
  guestLastName  String
  guestPhone     String?
  createdAt     DateTime   @default(now())
  auditLogs      EventAuditLog[]

  @@index([eventId])
  @@index([guestPhone])
}

// Registro a eventos
model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status        RegistrationStatus @default(CONFIRMED)
  removalReason String?            // Motivo de expulsión por el organizador (desplegable fijo)

  cancelledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
  @@index([status])
}

// Membresía del usuario
model Membership {
  id                String         @id @default(cuid())
  userId            String         @unique
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              MembershipType @default(COLABORADOR)
  iban              String?
  notes             String?        @db.Text  // Observaciones internas del admin

  // Fechas importantes
  memberSince       DateTime?      // Fecha real de alta en el club (del CSV histórico)
  startDate         DateTime       @default(now())  // Fecha de inicio como miembro
  becameSocioAt     DateTime?      // Fecha en que pasó a SOCIO (si aplica)
  fechaBaja         DateTime?      // Fecha de baja del miembro
  trialStartDate    DateTime?      // Fecha de inicio del período de prueba actual (se rellena al marcar EN_PRUEBAS manualmente)
  billingStartDate  DateTime?      // Primer día del mes desde el que se exige pago (mes siguiente al paso a COLABORADOR)

  // Estado de pagos
  isActive          Boolean        @default(true)   // Si está al día con los pagos
  lastPaymentDate   DateTime?      // Último pago registrado
  nextPaymentDue    DateTime?      // Próxima fecha de pago

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isActive])
  @@index([fechaBaja])
}

// Historial de cambios de tipo de membresía
model MembershipChangeLog {
  id            String         @id @default(cuid())
  userId        String

  // Cambio realizado
  previousType  MembershipType?  // null si es la primera membresía
  newType       MembershipType
  reason        String?          @db.Text  // Motivo del cambio

  // Auditoría
  changedBy     String           // ID del admin que hizo el cambio
  changedAt     DateTime         @default(now())

  createdAt     DateTime         @default(now())

  @@index([userId])
  @@index([changedAt])
  @@index([changedBy])
}

model PaymentMonthConsolidation {
  id             String   @id @default(cuid())
  year           Int
  month          Int
  consolidatedAt DateTime @default(now())
  consolidatedBy String

  @@unique([year, month])
  @@index([consolidatedAt])
}

// Registro de pagos
model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount          Decimal  @db.Decimal(10, 2)
  month           Int      // 1-12
  year            Int      // 2024, 2025, etc.

  // Información del pago
  paymentMethod   String?  // "efectivo", "transferencia", "bizum", etc.
  reference       String?  // Número de referencia o comprobante
  notes           String?  @db.Text

  // Registro
  registeredBy    String   // Admin que registró el pago
  paidAt          DateTime @default(now())

  createdAt       DateTime @default(now())

  @@unique([userId, month, year]) // Un pago por mes/año por usuario
  @@index([userId])
  @@index([year, month])
  @@index([paidAt])
}

// Juego de mesa (BoardGameGeek)
model Game {
  id                String   @id // BGG ID

  // Nombres
  name              String   // Nombre principal
  alternateNames    String[] // Nombres alternativos en otros idiomas

  // Información básica
  description       String?  @db.Text
  yearPublished     Int?

  // Imágenes
  image             String?  // URL de imagen grande
  thumbnail         String?  // URL de miniatura

  // Jugadores
  minPlayers        Int?
  maxPlayers        Int?

  // Tiempo de juego (en minutos)
  playingTime       Int?     // Tiempo típico
  minPlaytime       Int?     // Tiempo mínimo
  maxPlaytime       Int?     // Tiempo máximo

  // Edad
  minAge            Int?

  // Estadísticas de BGG
  usersRated        Int?
  averageRating     Float?
  bayesAverage      Float?
  rank              Int?     // Overall rank
  strategyRank      Int?     // Strategy game rank
  complexityRating  Float?   // Weight/complexity (1-5)

  // Comunidad
  numOwned          Int?
  numWanting        Int?
  numWishing        Int?
  numComments       Int?

  // Categorías (arrays de strings)
  categories        String[] // Economic, Exploration, Nautical, Pirates, etc.
  mechanics         String[] // Hand Management, Set Collection, etc.
  families          String[] // Components, Themes, etc.

  // Categoría para badges (asignada manualmente)
  badgeCategory     BadgeCategory?

  // Categoría confirmada por consenso de la comunidad (2 votos coincidentes)
  confirmedCategory BadgeCategory?

  // Votos de categoría de la comunidad
  categoryVotes     GameCategoryVote[]

  // Creadores
  designers         String[] // Nombres de diseñadores
  artists           String[] // Nombres de artistas
  publishers        String[] // Editoriales

  // Metadatos
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastSyncedAt      DateTime @default(now()) // Última vez que se sincronizó con BGG

  // Relación con eventos
  events            Event[]  @relation("GameEvents")
  userGames         UserGame[]
  eventExpansions   EventExpansion[]

  @@index([name])
  @@index([yearPublished])
  @@index([rank])
  @@index([averageRating])
}

enum BggSyncJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Configuración del club
model ClubConfig {
  id        String   @id @default("club_config") // Solo habrá un registro

  // Tipos de membresía disponibles con sus configuraciones
  membershipTypes Json // Array de objetos con: { type, displayName, price, hasKey, description }

  // Otras configuraciones del club
  clubName       String   @default("Club Dreadnought")
  clubEmail      String?
  clubPhone      String?
  clubAddress    String?

  // Configuración de cuotas
  defaultCurrency String  @default("EUR")
  inviteMaxActive Int     @default(5)
  inviteMaxMonthly Int    @default(10)
  inviteMaxGuestYear Int  @default(5)
  inviteAllowSelfValidation Boolean @default(false)

  // Personalización visual
  loginParticleStyle String @default("white") // "white" | "neon" | "theme"

  // Analytics de navegación
  pageViewCollectionStartedAt DateTime? // Fecha desde la que se recogen datos de navegación

  // Metadatos
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Tipos de juegos en la ludoteca
enum GameType {
  WARGAME
  MESA
  CARTAS
  MINI
  ROL
}

// Estados de condición física del juego
enum GameCondition {
  NUEVO
  BUENO
  REGULAR
  MALO
}

// Item físico en la ludoteca del club
model LibraryItem {
  id                String         @id @default(cuid())

  // Identificadores
  bggId             String?        // BGG ID del juego (almacenado como referencia, puede no estar en la tabla Game)
  internalId        String         @unique // ID interno del club

  // Información del juego
  name              String
  description       String?        @db.Text
  notes             String?        @db.Text
  thumbnail         String?        // URL de miniatura (BGG o RPGGeek, cacheada)
  image             String?        // URL de imagen completa (BGG o RPGGeek, cacheada)
  yearPublished     Int?           // Año de publicación (BGG o RPGGeek, cacheado)

  // Clasificación
  gameType          GameType       // wargame, mesa, cartas, mini, rol
  condition         GameCondition  // Nuevo, Bueno, Regular, Malo

  // Propiedad y adquisición
  ownerEmail        String?        // Email del propietario (si no es del club)
  acquisitionDate   DateTime?      // Fecha de adquisición

  // Metadatos
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([name])
  @@index([gameType])
  @@index([condition])
  @@index([ownerEmail])
  @@index([bggId])
}

// Visibilidad de documentos
enum DocumentVisibility {
  PUBLIC      // Todos los miembros autenticados
  SOCIOS      // Solo miembros con tipo SOCIO (+ admins)
  ADMIN       // Solo ADMIN y SUPER_ADMIN
  SUPER_ADMIN // Solo SUPER_ADMIN
}

// Documentos del club
model Document {
  id            String             @id @default(cuid())

  // Metadatos del archivo
  title         String
  filename      String             // Nombre original del archivo
  mimeType      String             // application/pdf, image/png, etc.
  size          Int                // Tamaño en bytes

  // Cloudinary storage
  cloudinaryId  String             // public_id de Cloudinary
  url           String             // Secure URL del documento

  // Estadísticas
  downloadCount Int                @default(0)

  // Permisos/Visibilidad
  visibility    DocumentVisibility @default(PUBLIC)

  // Auditoría
  uploadedById  String
  uploadedBy    User               @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([visibility])
  @@index([uploadedById])
  @@index([title])
}

// Fotos de eventos (almacenadas en Cloudinary)
model EventPhoto {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Datos de Cloudinary
  cloudinaryId  String   // public_id de Cloudinary
  url           String   // URL de la imagen
  thumbnailUrl  String?  // URL de miniatura (transformación de Cloudinary)

  // Metadatos
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id])
  caption       String?  // Descripción opcional de la foto

  createdAt     DateTime @default(now())

  @@index([eventId])
  @@index([uploadedById])
}


model Report {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             ReportType
  title            String
  description      String         @db.Text
  screenshotUrl    String?
  originUrl        String?
  status           ReportStatus   @default(NUEVO)
  internalPriority ReportPriority @default(MEDIA)
  perceivedSeverity ReportSeverity
  platform         ReportPlatform @default(MOVIL)
  mobileOs         String?
  devResponse      String?        @db.Text
  votesCount       Int            @default(0)

  // Threading y asignación
  assignedToId     String?
  assignedTo       User?          @relation("AssignedReports", fields: [assignedToId], references: [id])
  comments         ReportComment[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  votes            ReportVote[]

  @@index([userId])
  @@index([status])
  @@index([internalPriority])
  @@index([createdAt])
  @@index([assignedToId])
}

model ReportVote {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reportId, userId])
  @@index([reportId])
  @@index([userId])
}

// Comentarios en reportes (threading)
model ReportComment {
  id        String                 @id @default(cuid())
  reportId  String
  report    Report                 @relation(fields: [reportId], references: [id], onDelete: Cascade)
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String                 @db.Text
  imageUrls String[]               @default([])
  createdAt DateTime               @default(now())
  editedAt  DateTime?
  history   ReportCommentHistory[]

  @@index([reportId])
  @@index([userId])
  @@index([createdAt])
}

model ReportCommentHistory {
  id        String        @id @default(cuid())
  commentId String
  comment   ReportComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  content   String        @db.Text
  imageUrls String[]      @default([])
  editedAt  DateTime      @default(now())

  @@index([commentId])
}

enum EventAuditAction {
  REGISTER
  UNREGISTER
  REMOVE_PARTICIPANT
  INVITE
  CANCEL_INVITE
  CLOSE_CAPACITY
}

model EventAuditLog {
  id            String           @id @default(cuid())
  eventId       String
  event         Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actorId       String
  actor         User             @relation("EventAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action        EventAuditAction
  targetUserId  String?
  targetUser    User?            @relation("EventAuditTargetUser", fields: [targetUserId], references: [id])
  targetGuestId String?
  targetGuest   EventGuest?      @relation(fields: [targetGuestId], references: [id])
  createdAt     DateTime         @default(now())
  details       String?          @db.Text

  @@index([eventId])
  @@index([actorId])
  @@index([action])
}

// Categorías de badges
enum BadgeCategory {
  EUROGAMES
  TEMATICOS
  WARGAMES
  ROL
  MINIATURAS
  WARHAMMER
  FILLERS_PARTY
  CARTAS_LCG_TCG
  CATALOGADOR
  ORGANIZADOR
  REPETIDOR
  VALIDADOR
  TESTIGO_MESA
  AUDITOR_LUDICO
  CONOCEDOR_GENEROS
  FOTOGRAFO
}

// Tipos de notificaciones
enum NotificationType {
  EVENT_CANCELLED         // Partida cancelada
  EVENT_MODIFIED          // Partida modificada (fecha/hora/ubicación)
  EVENT_CREATED           // Nueva partida creada (si tiene habilitadas las notificaciones)
  EVENT_REMINDER          // Recordatorio 24h antes
  USER_APPROVED           // Tu solicitud fue aprobada
  USER_REJECTED           // Tu solicitud fue rechazada
  ADMIN_NEW_USER          // Nuevo usuario pendiente de aprobación (para admins)
  INVITATION_VALIDATED    // Tu invitación fue validada
  INVITATION_REJECTED     // Tu invitación fue rechazada
  WAITLIST_SPOT_AVAILABLE // Plaza disponible desde waitlist
  BADGE_UNLOCKED          // Badge desbloqueado
  REGISTRATION_PENDING    // Solicitud de registro pendiente (para organizador)
  REGISTRATION_APPROVED   // Registro aprobado (para usuario)
  REGISTRATION_REJECTED   // Registro rechazado (para usuario)
  REPORT_CREATED          // Nuevo reporte creado (para admins)
  REPORT_UPDATED          // Reporte actualizado (para creador)
  REPORT_COMMENT          // Nuevo comentario en reporte
  EVENT_DISPUTE_CONFIRMATION // Confirmar si la partida se disputó (para organizador)
  ANNOUNCEMENT_CREATED       // Nuevo anuncio publicado en el tablón
  MEMBER_PROMOTED            // Miembro EN_PRUEBAS promovido a COLABORADOR automáticamente
  MARKETPLACE_NEW_MESSAGE      // Nuevo mensaje en conversación de mercadillo
  MARKETPLACE_NEW_OFFER        // Nueva oferta recibida
  MARKETPLACE_OFFER_ACCEPTED   // Tu oferta fue aceptada
  MARKETPLACE_OFFER_REJECTED   // Tu oferta fue rechazada
  MARKETPLACE_OFFER_COUNTERED  // El vendedor ha contraofertado
  MARKETPLACE_NEW_CONVERSATION // Alguien ha abierto un hilo sobre tu anuncio
}

// Notificaciones del sistema
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String           @db.Text

  // Datos adicionales (JSON)
  metadata  Json?            // { eventId, eventTitle, etc. }

  // Estado
  read      Boolean          @default(false)
  readAt    DateTime?

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// Notificaciones globales (broadcast a todos los usuarios)
model GlobalNotification {
  id        String           @id @default(cuid())

  type      NotificationType
  title     String
  message   String           @db.Text
  metadata  Json?

  createdAt DateTime         @default(now())

  reads     GlobalNotificationRead[]

  @@index([createdAt])
  @@index([type])
}

// Registro de lectura/descarte de notificaciones globales por usuario
model GlobalNotificationRead {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  globalNotificationId String
  globalNotification   GlobalNotification @relation(fields: [globalNotificationId], references: [id], onDelete: Cascade)

  readAt    DateTime  @default(now())
  dismissed Boolean   @default(false)

  @@unique([userId, globalNotificationId])
  @@index([userId])
  @@index([globalNotificationId])
  @@index([userId, dismissed])
}

// Definiciones de badges (catálogo estático)
model BadgeDefinition {
  id            String        @id @default(cuid())
  category      BadgeCategory
  level         Int           // 1-6
  name          String        // "Euro-turista", "Capataz de Recursos", etc.
  description   String?       @db.Text
  iconUrl       String?       // URL del icono del badge
  requiredCount Int           // Juegos necesarios: 5, 10, 20, 40, 70, 100

  // Relaciones
  userBadges    UserBadge[]

  createdAt     DateTime      @default(now())

  @@unique([category, level])
  @@index([category])
  @@index([level])
}

// Votos de categoría de juego por la comunidad
model GameCategoryVote {
  id        String        @id @default(cuid())
  bggId     String
  game      Game          @relation(fields: [bggId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  BadgeCategory
  createdAt DateTime      @default(now())

  @@unique([bggId, userId])
  @@index([bggId])
  @@index([userId])
}

// Historial de consensos de categoría (para badge CONOCEDOR_GENEROS)
model GenreConsensusHistory {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bggId     String
  category  BadgeCategory
  createdAt DateTime      @default(now())

  @@unique([userId, bggId])
  @@index([userId])
}

// Validación cruzada de partidas por QR
model GameValidation {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scannerId   String   // quien escaneó el QR del otro
  scanner     User     @relation("GameValidationScanner", fields: [scannerId], references: [id], onDelete: Cascade)
  scannedId   String   // cuyo QR fue escaneado
  scanned     User     @relation("GameValidationScanned", fields: [scannedId], references: [id], onDelete: Cascade)
  validatedAt DateTime @default(now())

  @@unique([eventId, scannerId, scannedId])
  @@index([eventId])
  @@index([scannerId])
  @@index([scannedId])
}

// Badges desbloqueados por usuarios
model UserBadge {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeDefinitionId String
  badgeDefinition   BadgeDefinition @relation(fields: [badgeDefinitionId], references: [id], onDelete: Cascade)
  unlockedAt        DateTime        @default(now())

  @@unique([userId, badgeDefinitionId])
  @@index([userId])
  @@index([badgeDefinitionId])
}

// Historial de juegos jugados (para tracking de badges)
model GamePlayHistory {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId      String
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  gameName     String         // Nombre del juego jugado
  gameCategory BadgeCategory? // Categoría del juego (puede ser null si no está categorizado)
  playedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())

  @@index([userId])
  @@index([eventId])
  @@index([gameCategory])
  @@index([playedAt])
}

// ==================== JUEGO AZUL ====================

enum AzulGameStatus {
  WAITING   // Esperando segundo jugador
  ACTIVE    // Partida en curso
  FINISHED  // Partida terminada
}

// Partida del juego de mesa Azul (2 jugadores, turnos online)
model AzulGame {
  id          String          @id @default(cuid())
  player1Id   String
  player1     User            @relation("AzulGamesAsPlayer1", fields: [player1Id], references: [id])
  player2Id   String?
  player2     User?           @relation("AzulGamesAsPlayer2", fields: [player2Id], references: [id])
  gameState   Json            // Estado completo del tablero (factories, walls, scores, etc.)
  currentTurn String?         // userId del jugador que tiene el turno
  status      AzulGameStatus  @default(WAITING)
  winnerId    String?         // userId del ganador (null si empate o no terminada)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@index([createdAt])
}

// ==================== JUEGO VIERNES ====================

enum ViernesGameStatus {
  ACTIVE    // Partida en curso (solitario: activa desde el momento de creación)
  FINISHED  // Partida terminada
}

// Partida del juego solitario Viernes (Friday/Freitag de Friedemann Friese)
model ViernesGame {
  id         String             @id @default(cuid())
  playerId   String
  player     User               @relation("ViernesGamesAsPlayer", fields: [playerId], references: [id])
  gameState  Json               // ViernesGameState completo
  difficulty Int                // 1-4 (nivel de dificultad)
  status     ViernesGameStatus  @default(ACTIVE)
  won        Boolean?           // null hasta terminar
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([playerId])
  @@index([status])
  @@index([createdAt])
}

// ==================== GESTIÓN FINANCIERA ====================

enum FinancialCategoryType {
  GASTO
  INGRESO
}

enum FinancialAttachmentType {
  IMAGE
  PDF
}

// Categorías de gastos/ingresos
model FinancialCategory {
  id              String                  @id @default(cuid())
  name            String                  @unique // Nombre de la categoría (ej: "Alquiler", "Luz")
  type            FinancialCategoryType   // GASTO o INGRESO
  icon            String                  @default("💰") // Emoji o icono para la categoría
  color           String                  @default("bg-blue-100 text-blue-800") // Clases de color para UI
  showInBalance   Boolean                 @default(true) // Si se muestra en el balance
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  movements       FinancialMovement[]

  @@index([showInBalance])
}

// Movimientos financieros (ingresos y gastos)
model FinancialMovement {
  id              String            @id @default(cuid())
  categoryId      String
  category        FinancialCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount          Float             // Monto del movimiento (positivo para ingresos, negativo para gastos)
  description     String?           // Descripción opcional del movimiento
  date            DateTime          // Fecha del movimiento
  year            Int               // Año extraído para facilitar consultas
  month           Int               // Mes (1-12) extraído para facilitar consultas
  createdBy       String            // Usuario que creó el movimiento
  user            User              @relation("FinancialMovements", fields: [createdBy], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attachments     FinancialMovementAttachment[]

  @@index([categoryId])
  @@index([year, month])
  @@index([date])
  @@index([createdBy])
}

model FinancialMovementAttachment {
  id          String                  @id @default(cuid())
  movementId  String
  movement    FinancialMovement       @relation(fields: [movementId], references: [id], onDelete: Cascade)
  url         String
  fileType    FinancialAttachmentType
  fileName    String
  cloudinaryId String
  createdAt   DateTime                @default(now())

  @@index([movementId])
}

// ==================== ANALYTICS DE NAVEGACIÓN ====================

model PageView {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  path        String   // Ruta visitada, ej: /events, /profile
  visitedAt   DateTime @default(now())

  @@index([userId])
  @@index([path])
  @@index([visitedAt])
}

// Archivo histórico de analytics (tras un reset)
model PageViewArchive {
  id          String   @id @default(cuid())
  archivedAt  DateTime @default(now())
  fromDate    DateTime // Fecha de inicio del periodo archivado
  toDate      DateTime // Fecha de fin del periodo archivado
  totalViews  Int      // Total de registros archivados
  data        Json     // Snapshot agregado: top páginas, usuarios activos, etc.
}

// ─── Mercadillo ───────────────────────────────────────────────────────────────

enum MarketplaceListingStatus {
  PUBLICADO
  RESERVADO
  VENDIDO
}

enum MarketplaceOfferStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
  CANCELADA
  CONTRAOFERTA
}

enum MarketplaceCancellationRole {
  BUYER
  SELLER
}

enum MarketplaceCategory {
  JUEGOS_MESA
  ROL
  WARGAMES
  MINIATURAS
  ACCESORIOS
  MATERIAL_RELACIONADO
}

model MarketplaceListing {
  id           String                   @id @default(cuid())
  authorId     String
  author       User                     @relation("MarketplaceListingAuthor", fields: [authorId], references: [id])
  title        String
  description  String                   @db.Text
  category     MarketplaceCategory
  price        Decimal                  @db.Decimal(10, 2)
  status       MarketplaceListingStatus @default(PUBLICADO)
  images       String[]
  contactExtra String?
  isArchived   Boolean                  @default(false)
  isHidden     Boolean                  @default(false)
  viewsCount   Int                      @default(0)

  conversations MarketplaceConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([category])
  @@index([isArchived])
  @@index([isHidden])
}

model MarketplaceConversation {
  id        String             @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User               @relation("MarketplaceConversationBuyer", fields: [buyerId], references: [id])

  messages      MarketplaceMessage[]
  offers        MarketplaceOffer[]
  cancellations MarketplaceCancellation[]
  reads         MarketplaceConversationRead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@index([buyerId])
}

model MarketplaceConversationRead {
  id             String                  @id @default(cuid())
  conversationId String
  conversation   MarketplaceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                    @relation("MarketplaceConversationReadUser", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime                @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model MarketplaceMessage {
  id             String                  @id @default(cuid())
  conversationId String
  conversation   MarketplaceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User                    @relation("MarketplaceMessageSender", fields: [senderId], references: [id])
  body           String                  @db.Text

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
}

model MarketplaceOffer {
  id             String                  @id @default(cuid())
  conversationId String
  conversation   MarketplaceConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  proposedById   String
  proposedBy     User                    @relation("MarketplaceOfferProposer", fields: [proposedById], references: [id])
  amount         Decimal                 @db.Decimal(10, 2)
  status         MarketplaceOfferStatus  @default(PENDIENTE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  @@index([proposedById])
}

model MarketplaceCancellation {
  id             String                      @id @default(cuid())
  conversationId String
  conversation   MarketplaceConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  cancelledById  String
  cancelledBy    User                        @relation("MarketplaceCancellationUser", fields: [cancelledById], references: [id])
  role           MarketplaceCancellationRole
  reason         String

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([cancelledById])
}

// ==================== LUDOTECA PERSONAL ====================

model GameLocation {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime   @default(now())
  games     UserGame[]

  @@unique([userId, name])
  @@index([userId])
}

model UserGame {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId           String
  game             Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  own              Boolean       @default(false)
  wishlist         Boolean       @default(false)
  wishlistPriority Int?          // 1-5
  wantToPlay       Boolean       @default(false)
  locationId       String?       // null = "Casa" (ubicación por defecto)
  location         GameLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status           String        @default("active") // "active" | "deleted" (soft delete)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([userId, gameId])
  @@index([userId])
  @@index([userId, status])
  @@index([locationId])
  @@index([gameId])
}

model BggSyncJob {
  id               String           @id @default(cuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bggUsername      String
  status           BggSyncJobStatus @default(PENDING)
  locationId       String?
  requestedAt      DateTime         @default(now())
  startedAt        DateTime?
  finishedAt       DateTime?
  error            String?          @db.Text
  totalToImport    Int              @default(0)
  totalToDelete    Int              @default(0)
  processed        Int              @default(0)
  imported         Int              @default(0)
  linkedExisting   Int              @default(0)
  deleted          Int              @default(0)
  failed           Int              @default(0)
  estimatedSeconds Int              @default(0)
  importPayload    Json
  deletePayload    Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId, requestedAt])
  @@index([status, requestedAt])
}

// ==================== RESULTADOS DE PARTIDAS ====================

model EventResult {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String?  // null si el jugador es un invitado sin cuenta
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName String?  // nombre libre para jugadores sin cuenta
  score     Int?
  isWinner  Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  createdBy String
  creator   User     @relation("EventResultCreator", fields: [createdBy], references: [id])

  @@index([eventId])
  @@index([userId])
}
